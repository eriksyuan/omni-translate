{
  "name": "omnitranslate",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm i18n:prepare && vite",
    "build": "pnpm i18n:prepare && pnpm typecheck && vite build",
    "preview": "vite preview",
    "fetch-sherpa-sidecar": "bash scripts/fetch-sherpa-sidecar.sh",
    "tauri": "tauri",
    "i18n:validate": "node scripts/i18n/validate.mjs",
    "i18n:sync": "node scripts/i18n/sync.mjs",
    "i18n:prepare": "pnpm i18n:validate && pnpm i18n:sync",
    "typecheck": "tsc --noEmit -p tsconfig.json --pretty && tsc --noEmit -p tsconfig.node.json --pretty",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml --all",
    "rust:fmt:check": "cargo fmt --manifest-path src-tauri/Cargo.toml --all -- --check",
    "rust:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "rust:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
    "check": "pnpm i18n:prepare && pnpm typecheck && pnpm lint && pnpm format:check && pnpm test && pnpm rust:fmt:check && pnpm rust:check"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-slider": "^1.4.1",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-toggle-group": "^1.1.13",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@unocss/preset-attributify": "^66.7.3",
    "@unocss/preset-icons": "^66.7.3",
    "@unocss/vite": "^66.7.3",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.62.0",
    "unocss": "^66.7.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.9"
  }
}
