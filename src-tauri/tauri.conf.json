{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OmniTranslate",
  "version": "0.1.0",
  "identifier": "com.omnitranslate.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "audio-config",
        "title": "音频实时翻译配置",
        "width": 440,
        "height": 560,
        "visible": false,
        "center": true,
        "resizable": false,
        "minWidth": 400,
        "minHeight": 480
      },
      {
        "label": "ocr-permission",
        "title": "需要屏幕录制权限",
        "width": 480,
        "height": 520,
        "visible": false,
        "center": true,
        "resizable": false
      },
      {
        "label": "ocr-overlay",
        "title": "OCR 选区",
        "fullscreen": true,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true
      },
      {
        "label": "subtitle",
        "title": "字幕",
        "width": 860,
        "height": 280,
        "minWidth": 520,
        "maxWidth": 1400,
        "minHeight": 140,
        "maxHeight": 560,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true
      },
      {
        "label": "preferences",
        "title": "偏好设置",
        "width": 860,
        "height": 580,
        "visible": false,
        "center": true,
        "minWidth": 720,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/sherpa-onnx-online-websocket-server"
    ],
    "resources": {
      "resources/locales/*": "locales/",
      "binaries/lib/": "sherpa-lib/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "14.0",
      "infoPlist": "./Info.plist",
      "entitlements": "./Entitlements.plist"
    }
  }
}
